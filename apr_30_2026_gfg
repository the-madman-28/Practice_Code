class Solution {
public:
    bool isMaxHeap(vector<int> &arr) {
        int n = arr.size();

        // check all non-leaf nodes
        for (int i = 0; i <= (n / 2) - 1; i++) {
            int left = 2 * i + 1;
            int right = 2 * i + 2;

            // check left child
            if (left < n && arr[i] < arr[left])
                return false;

            // check right child
            if (right < n && arr[i] < arr[right])
                return false;
        }

        return true;
    }
};
