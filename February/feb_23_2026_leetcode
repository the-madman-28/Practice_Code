class Solution {
public:
    bool hasAllCodes(string s, int k) {
        
        int n = s.length();
        
        if (n < k) return false;
        
        unordered_set<string> st;
        
        for (int i = 0; i <= n - k; i++) {
            st.insert(s.substr(i, k));
            
            // Early stopping
            if (st.size() == (1 << k))
                return true;
        }
        
        return st.size() == (1 << k);
    }
};
