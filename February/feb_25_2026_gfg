class Solution {
  public:
    int longestSubarray(vector<int> &arr, int k) {
        
        unordered_map<int, int> firstIndex;
        int prefix = 0;
        int maxLen = 0;
        
        for(int i = 0; i < arr.size(); i++) {
            
            // Transform condition
            if(arr[i] > k)
                prefix += 1;
            else
                prefix -= 1;
            
            // If prefix > 0, whole subarray (0 to i) is valid
            if(prefix > 0) {
                maxLen = i + 1;
            }
            else {
                // Check if (prefix - 1) seen before
                if(firstIndex.find(prefix - 1) != firstIndex.end()) {
                    maxLen = max(maxLen, i - firstIndex[prefix - 1]);
                }
            }
            
            // Store first occurrence of prefix
            if(firstIndex.find(prefix) == firstIndex.end()) {
                firstIndex[prefix] = i;
            }
        }
        
        return maxLen;
    }
};
