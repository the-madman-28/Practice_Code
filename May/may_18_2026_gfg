class Solution {
  public:
  
    unordered_map<int, int> dp;
  
    int solve(int n) {
        
        // base case
        if(n == 0)
            return 0;
        
        // already computed
        if(dp.count(n))
            return dp[n];
        
        int breakValue =
            solve(n / 2) +
            solve(n / 3) +
            solve(n / 4);
        
        return dp[n] = max(n, breakValue);
    }
  
    int maxSum(int n) {
        return solve(n);
    }
};
