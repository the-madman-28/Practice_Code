class Solution {
  public:
  
    bool oppositeSign(int a, int b) {
        return (a >= 0 && b < 0) || (a < 0 && b >= 0);
    }
  
    vector<int> makeBeautiful(vector<int> arr) {
        
        vector<int> st;
        
        for(int x : arr) {
            
            if(!st.empty() && oppositeSign(st.back(), x)) {
                st.pop_back();
            }
            else {
                st.push_back(x);
            }
        }
        
        return st;
    }
};
