class Solution {
  public:
    vector<Node*> findPreSuc(Node* root, int key) {
        
        Node* pre = NULL;
        Node* suc = NULL;
        
        Node* curr = root;
        
        while (curr) {
            
            if (curr->data < key) {
                pre = curr;
                curr = curr->right;
            }
            else if (curr->data > key) {
                suc = curr;
                curr = curr->left;
            }
            else {
                
                // predecessor = max in left subtree
                Node* t = curr->left;
                while (t) {
                    pre = t;
                    t = t->right;
                }
                
                // successor = min in right subtree
                t = curr->right;
                while (t) {
                    suc = t;
                    t = t->left;
                }
                
                break;
            }
        }
        
        return {pre, suc};
    }
};
