class Solution {
  public:
    
    int dfs(Node* root, long long currSum, int k,
            unordered_map<long long, int> &mp) {
        
        if (!root) return 0;
        
        currSum += root->data;
        
        int count = 0;
        
        // if sum == k from root
        if (currSum == k) count++;
        
        // check previous prefix
        if (mp.find(currSum - k) != mp.end())
            count += mp[currSum - k];
        
        // store current sum
        mp[currSum]++;
        
        // go left and right
        count += dfs(root->left, currSum, k, mp);
        count += dfs(root->right, currSum, k, mp);
        
        // backtrack
        mp[currSum]--;
        
        return count;
    }
    
    
    int countAllPaths(Node *root, int k) {
        unordered_map<long long, int> mp;
        return dfs(root, 0, k, mp);
    }
};
