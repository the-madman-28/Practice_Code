class Solution {
  public:
    int maxArea(vector<int> &height) {
        int n = height.size();
        int l = 0, r = n - 1;
        int ans = 0;

        while (l < r) {
            int width = r - l - 1;
            int area = min(height[l], height[r]) * width;
            ans = max(ans, area);

            if (height[l] < height[r])
                l++;
            else
                r--;
        }

        return ans;
    }
};
