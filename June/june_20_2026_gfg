class Solution {
  public:
    int getLastDigit(string& a, string& b) {
        
        if (b == "0")
            return 1;
        
        int base = a.back() - '0';
        
        int exp = 0;
        for (char c : b) {
            exp = (exp * 10 + (c - '0')) % 4;
        }
        
        if (exp == 0)
            exp = 4;
        
        int ans = 1;
        
        while (exp--) {
            ans = (ans * base) % 10;
        }
        
        return ans;
    }
};
