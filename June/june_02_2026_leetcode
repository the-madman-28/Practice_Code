class Solution {
public:
    int earliestFinishTime(vector<int>& landStartTime, vector<int>& landDuration,
                           vector<int>& waterStartTime, vector<int>& waterDuration) {

        long long ans = LLONG_MAX;

        int n = landStartTime.size();
        int m = waterStartTime.size();

        // Water preprocessing
        vector<pair<int,int>> water;
        for (int i = 0; i < m; i++) {
            water.push_back({waterStartTime[i], waterDuration[i]});
        }
        sort(water.begin(), water.end());

        vector<int> wStart(m);
        vector<long long> prefMinDur(m), suffMinOpenPlusDur(m);

        for (int i = 0; i < m; i++) {
            wStart[i] = water[i].first;
            prefMinDur[i] = water[i].second;
            if (i) prefMinDur[i] = min(prefMinDur[i], prefMinDur[i - 1]);
        }

        for (int i = m - 1; i >= 0; i--) {
            suffMinOpenPlusDur[i] =
                1LL * water[i].first + water[i].second;

            if (i + 1 < m)
                suffMinOpenPlusDur[i] =
                    min(suffMinOpenPlusDur[i], suffMinOpenPlusDur[i + 1]);
        }

        // Land -> Water
        for (int i = 0; i < n; i++) {
            long long landFinish =
                1LL * landStartTime[i] + landDuration[i];

            int pos = upper_bound(wStart.begin(), wStart.end(),
                                  landFinish) - wStart.begin();

            if (pos > 0) {
                ans = min(ans,
                          landFinish + prefMinDur[pos - 1]);
            }

            if (pos < m) {
                ans = min(ans,
                          suffMinOpenPlusDur[pos]);
            }
        }

        // Land preprocessing
        vector<pair<int,int>> land;
        for (int i = 0; i < n; i++) {
            land.push_back({landStartTime[i], landDuration[i]});
        }
        sort(land.begin(), land.end());

        vector<int> lStart(n);
        vector<long long> prefMinDurLand(n), suffMinOpenPlusDurLand(n);

        for (int i = 0; i < n; i++) {
            lStart[i] = land[i].first;
            prefMinDurLand[i] = land[i].second;
            if (i) prefMinDurLand[i] =
                min(prefMinDurLand[i], prefMinDurLand[i - 1]);
        }

        for (int i = n - 1; i >= 0; i--) {
            suffMinOpenPlusDurLand[i] =
                1LL * land[i].first + land[i].second;

            if (i + 1 < n)
                suffMinOpenPlusDurLand[i] =
                    min(suffMinOpenPlusDurLand[i],
                        suffMinOpenPlusDurLand[i + 1]);
        }

        // Water -> Land
        for (int j = 0; j < m; j++) {
            long long waterFinish =
                1LL * waterStartTime[j] + waterDuration[j];

            int pos = upper_bound(lStart.begin(), lStart.end(),
                                  waterFinish) - lStart.begin();

            if (pos > 0) {
                ans = min(ans,
                          waterFinish + prefMinDurLand[pos - 1]);
            }

            if (pos < n) {
                ans = min(ans,
                          suffMinOpenPlusDurLand[pos]);
            }
        }

        return (int)ans;
    }
};
